  "performance": {
    "core_web_vitals": {
      "lcp": { "metric": "Largest Contentful Paint", "target": "< 2.5s", "optimize": "Lazy load images, use CDN, optimize hero image" },
      "fid": { "metric": "First Input Delay", "target": "< 100ms", "optimize": "Minimize JavaScript, code splitting" },

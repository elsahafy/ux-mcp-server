{
  "name": "@elsahafy/ux-mcp-server",
  "version": "4.1.0",
  "description": "MCP server providing 28 UX knowledge resources, 23 analysis tools & 4 workflow prompts. Works with Claude, Cursor, Continue.dev, Cline, Zed & any MCP client. Complete UX ecosystem coverage.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ux-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "knowledge",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc && node dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ux",
    "user-experience",
    "accessibility",
    "a11y",
    "wcag",
    "design-systems",
    "usability",
    "nielsen-heuristics",
    "ui-patterns",
    "ai-tools",
    "claude",
    "cursor",
    "continue-dev",
    "cline",
    "zed",
    "llm-tools",
    "ai-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elsahafy/ux-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/elsahafy/ux-mcp-server/issues"
  },
  "homepage": "https://github.com/elsahafy/ux-mcp-server#readme",
  "author": "Ibrahim Elsahafy",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
